# ── Master Agent Configuration ────────────────────────────────────────
# Copy to .env and fill in your values.
# All vars can also be set directly in your shell environment.

# Workspace root for task envelopes (default: ./workspace)
# MASTER_WORKSPACE=/path/to/workspace

# Default task timeout in seconds (default: 600)
# MASTER_TASK_TIMEOUT=600

# Max retry attempts on failure (default: 2)
# MASTER_MAX_RETRIES=2

# Default agent when auto-detection fails (default: claude-code)
# MASTER_DEFAULT_AGENT=claude-code

# ── Docker Image Overrides ────────────────────────────────────────────
# AGENT_IMAGE_CLAUDE_CODE=master-agent-claude-code:latest
# AGENT_IMAGE_OPENCODE=master-agent-opencode:latest
# AGENT_IMAGE_COPILOT=master-agent-copilot:latest

# ── Agent Environment Passthrough ─────────────────────────────────────
# Space-separated list of extra env vars to forward to each agent type.
# The defaults cover most common vars; add provider-specific ones here.
# AGENT_ENV_CLAUDE_CODE="MY_CUSTOM_VAR ANOTHER_VAR"
# AGENT_ENV_OPENCODE="MY_CUSTOM_VAR ANOTHER_VAR"
# AGENT_ENV_COPILOT="MY_CUSTOM_VAR ANOTHER_VAR"

# ── Provider: Anthropic (direct) ──────────────────────────────────────
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_BASE_URL=https://api.anthropic.com
# ANTHROPIC_MODEL=claude-sonnet-4-6

# ── Provider: DeepSeek (via Anthropic-compatible API) ─────────────────
# ANTHROPIC_BASE_URL=https://api.deepseek.com/anthropic
# ANTHROPIC_API_KEY=sk-...
# ANTHROPIC_MODEL=deepseek-v4-pro[1m]
# ANTHROPIC_DEFAULT_OPUS_MODEL=deepseek-v4-pro[1m]
# ANTHROPIC_DEFAULT_SONNET_MODEL=deepseek-v4-flash
# CLAUDE_CODE_EFFORT_LEVEL=max
# CLAUDE_CODE_SUBAGENT_MODEL=deepseek-v4-flash

# ── Provider: OpenAI-compatible ───────────────────────────────────────
# OPENAI_API_KEY=sk-...
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_MODEL=gpt-4o

# ── GitHub Copilot ────────────────────────────────────────────────────
# GITHUB_TOKEN=ghp_...
# GITHUB_HOST=github.com   # or github.mycompany.com for Enterprise

# ── Copilot with custom provider ──────────────────────────────────────
# COPILOT_PROVIDER_TYPE=anthropic
# COPILOT_PROVIDER_API_KEY=sk-...
# COPILOT_PROVIDER_BASE_URL=https://api.deepseek.com/anthropic
# COPILOT_MODEL=deepseek-v4-pro[1m]
# COPILOT_PROVIDER_MAX_OUTPUT_TOKENS=128000
# COPILOT_PROVIDER_MAX_PROMPT_TOKENS=840000

# ── Generic overrides (applied to all agents) ─────────────────────────
# AGENT_MODEL=deepseek-v4-pro[1m]
# AGENT_EFFORT=max
# AGENT_TIMEOUT=600
# AGENT_MAX_TOKENS=128000

# ── Network ───────────────────────────────────────────────────────────
# http_proxy=http://proxy:8080
# https_proxy=http://proxy:8080
# no_proxy=localhost,127.0.0.1
