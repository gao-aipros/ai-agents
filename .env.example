# ── Copy to .env and fill in your values ────────────────────────────────
# All vars can be set at runtime via -e or in your shell environment.

# ── GitHub tokens (one per agent) ─────────────────────────────────────────
# Each agent uses its own GitHub token for isolation and rate limiting.
MASTER_GH_TOKEN=ghp_...
WORKER_CLAUDE_GH_TOKEN=ghp_...
WORKER_COPILOT_GH_TOKEN=ghp_...
WORKER_OPENCODE_GH_TOKEN=ghp_...
WORKER_CODEX_GH_TOKEN=ghp_...

# ── Web UI ───────────────────────────────────────────────────────────────
# Optional: set a token to protect the web UI. If set, requests must include
# ?api_key=<token> in the query string or authenticate via Bearer <token>.
WEBUI_API_KEY=

# ── DeepSeek API Key (used by all 4 agents) ─────────────────────────────
DEEPSEEK_API_KEY=sk-...

# ── Claude Code worker ──────────────────────────────────────────────────
# ANTHROPIC_BASE_URL=https://api.deepseek.com/anthropic
# ANTHROPIC_AUTH_TOKEN=sk-...
# ANTHROPIC_MODEL=deepseek-v4-pro[1m]
# ANTHROPIC_DEFAULT_OPUS_MODEL=deepseek-v4-pro[1m]
# ANTHROPIC_DEFAULT_SONNET_MODEL=deepseek-v4-pro[1m]
# ANTHROPIC_DEFAULT_HAIKU_MODEL=deepseek-v4-flash
# CLAUDE_CODE_SUBAGENT_MODEL=deepseek-v4-flash
# CLAUDE_CODE_EFFORT_LEVEL=max

# ── Copilot worker ──────────────────────────────────────────────────────
# COPILOT_PROVIDER_TYPE=anthropic
# COPILOT_PROVIDER_BASE_URL=https://api.deepseek.com/anthropic
# COPILOT_PROVIDER_API_KEY=sk-...
# COPILOT_MODEL=deepseek-v4-pro[1m]
# COPILOT_PROVIDER_MAX_PROMPT_TOKENS=840000
# COPILOT_PROVIDER_MAX_OUTPUT_TOKENS=128000

# ── OpenCode worker ─────────────────────────────────────────────────────
# OPENCODE_PROVIDER=deepseek
# OPENCODE_MODEL=deepseek-v4-pro
# DEEPSEEK_API_KEY=sk-...

# ── Codex worker ─────────────────────────────────────────────────────────
# Uses moon-bridge proxy to translate OpenAI Responses API to DeepSeek Chat Completions.
# DEEPSEEK_API_KEY=sk-...

# ── Cloudflare Tunnel (web UI access) ────────────────────────────────────
# Create a tunnel at https://one.dash.cloudflare.com/ → Networks → Tunnels
# and point it to http://master:8000
CLOUDFLARED_TUNNEL_TOKEN=

# ── Redis (task queue) ──────────────────────────────────────────────────
# REDIS_HOST=redis
# REDIS_PORT=6379

# ── Docker image overrides ──────────────────────────────────────────────
# Set these to pull from GitHub Container Registry (ghcr.io) when running
# docker-compose with pre-built images on workers that don't build locally.
# WORKER_CLAUDE_IMAGE=ghcr.io/gao-aipros/worker-claude:latest
# WORKER_COPILOT_IMAGE=ghcr.io/gao-aipros/copilot:latest
# WORKER_OPENCODE_IMAGE=ghcr.io/gao-aipros/opencode:latest
# WORKER_CODEX_IMAGE=ghcr.io/gao-aipros/codex:latest
# MOON_BRIDGE_IMAGE=ghcr.io/gao-aipros/moon-bridge:latest
# MASTER_AGENT_IMAGE=ghcr.io/gao-aipros/master-agent:latest
