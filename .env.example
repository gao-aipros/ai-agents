# ── Copy to .env and fill in your values ────────────────────────────────
# All vars can be set at runtime via -e or in your shell environment.

# ── GitHub ──────────────────────────────────────────────────────────────
GH_TOKEN=ghp_...
GITHUB_TOKEN=ghp_...

# ── DeepSeek API Key (used by all 3 agents) ─────────────────────────────
DEEPSEEK_API_KEY=sk-...

# ── Claude Code worker ──────────────────────────────────────────────────
# ANTHROPIC_BASE_URL=https://api.deepseek.com/anthropic
# ANTHROPIC_AUTH_TOKEN=sk-...
# ANTHROPIC_MODEL=deepseek-v4-pro[1m]
# ANTHROPIC_DEFAULT_OPUS_MODEL=deepseek-v4-pro[1m]
# ANTHROPIC_DEFAULT_SONNET_MODEL=deepseek-v4-pro[1m]
# ANTHROPIC_DEFAULT_HAIKU_MODEL=deepseek-v4-flash
# CLAUDE_CODE_SUBAGENT_MODEL=deepseek-v4-flash
# CLAUDE_CODE_EFFORT_LEVEL=max

# ── Copilot worker ──────────────────────────────────────────────────────
# COPILOT_PROVIDER_TYPE=anthropic
# COPILOT_PROVIDER_BASE_URL=https://api.deepseek.com/anthropic
# COPILOT_PROVIDER_API_KEY=sk-...
# COPILOT_MODEL=deepseek-v4-pro[1m]
# COPILOT_PROVIDER_MAX_PROMPT_TOKENS=840000
# COPILOT_PROVIDER_MAX_OUTPUT_TOKENS=128000

# ── OpenCode worker ─────────────────────────────────────────────────────
# OPENCODE_PROVIDER=deepseek
# OPENCODE_MODEL=deepseek-v4-pro
# DEEPSEEK_API_KEY=sk-...

# ── Docker image overrides ──────────────────────────────────────────────
# Uncomment to pull from GitHub Container Registry (ghcr.io) on workers
# that don't have the images built locally.
# WORKER_CLAUDE_IMAGE=ghcr.io/noodle05/worker-claude:latest
# WORKER_COPILOT_IMAGE=ghcr.io/noodle05/copilot:latest
# WORKER_OPENCODE_IMAGE=ghcr.io/noodle05/opencode:latest
